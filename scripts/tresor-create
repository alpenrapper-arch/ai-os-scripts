#!/bin/bash
# Privat-Tresor erstellen — LUKS AES-256 verschlüsselt

TRESOR_FILE="$HOME/.privat-tresor.vault"
TRESOR_MOUNT="$HOME/Privat"
TRESOR_SIZE_MB=2048  # 2 GB default

# Größe abfragen
SIZE=$(kdialog --title "Tresor-Größe" \
  --menu "Wie groß soll dein Privat-Tresor sein?" \
  "512"  "512 MB" \
  "1024" "1 GB" \
  "2048" "2 GB (empfohlen)" \
  "5120" "5 GB" \
  "10240" "10 GB" 2>/dev/null)

[ $? -ne 0 ] && exit 0
TRESOR_SIZE_MB=$SIZE

# Passwort setzen
PASS1=$(kdialog --title "Tresor-Passwort" \
  --password "Wähle ein sicheres Passwort für deinen Tresor:\n(Mindestens 8 Zeichen)" 2>/dev/null)
[ $? -ne 0 ] && exit 0
[ ${#PASS1} -lt 8 ] && kdialog --error "Passwort zu kurz (mind. 8 Zeichen)!" 2>/dev/null && exit 1

PASS2=$(kdialog --title "Passwort bestätigen" \
  --password "Passwort wiederholen:" 2>/dev/null)
[ "$PASS1" != "$PASS2" ] && kdialog --error "Passwörter stimmen nicht überein!" 2>/dev/null && exit 1

# Tresor-Datei erstellen
kdialog --title "Tresor wird erstellt..." \
  --progressbar "Erstelle verschlüsselten Tresor ($((TRESOR_SIZE_MB/1024 > 0 ? TRESOR_SIZE_MB/1024 : TRESOR_SIZE_MB)) $([ $TRESOR_SIZE_MB -ge 1024 ] && echo GB || echo MB))..." 100 2>/dev/null &
PROG_PID=$!

# Leere Datei erstellen
dd if=/dev/urandom of="$TRESOR_FILE" bs=1M count="$TRESOR_SIZE_MB" status=none 2>/dev/null
chmod 600 "$TRESOR_FILE"

# LUKS formatieren
echo -n "$PASS1" | cryptsetup luksFormat \
  --type luks2 \
  --cipher aes-xts-plain64 \
  --key-size 512 \
  --hash sha512 \
  --pbkdf argon2id \
  --batch-mode \
  "$TRESOR_FILE" - 2>/dev/null

# Öffnen und formatieren
MAPPER="privat-tresor-$$"
echo -n "$PASS1" | cryptsetup luksOpen "$TRESOR_FILE" "$MAPPER" - 2>/dev/null
mkfs.ext4 -q -L "Privat-Tresor" "/dev/mapper/$MAPPER" 2>/dev/null
cryptsetup luksClose "$MAPPER" 2>/dev/null

# Mount-Punkt mit strikten Rechten erstellen
mkdir -p "$TRESOR_MOUNT"
chmod 700 "$TRESOR_MOUNT"

kill $PROG_PID 2>/dev/null

# Config speichern
mkdir -p "$HOME/.config/ai-os"
cat > "$HOME/.config/ai-os/tresor.conf" << EOF
TRESOR_FILE=$TRESOR_FILE
TRESOR_MOUNT=$TRESOR_MOUNT
CREATED=$(date -u +%Y-%m-%dT%H:%M:%SZ)
CIPHER=aes-xts-plain64
KEY_SIZE=512
HASH=sha512
PBKDF=argon2id
DSGVO_COMPLIANT=true
EOF
chmod 600 "$HOME/.config/ai-os/tresor.conf"

# auditd Regel für diesen Tresor eintragen
if command -v auditctl &>/dev/null; then
  echo "-w $TRESOR_MOUNT -p rwxa -k privat-tresor" | \
    sudo tee -a /etc/audit/rules.d/privat-tresor.rules > /dev/null 2>/dev/null || true
fi

kdialog --title "Tresor erstellt" \
  --msgbox "✅ Privat-Tresor erfolgreich erstellt!\n\n🔒 Verschlüsselung: AES-256-XTS\n🔐 Key-Derivierung: Argon2id\n📁 Speicherort: $TRESOR_FILE\n📂 Mount: $TRESOR_MOUNT\n\n🛡️ DSGVO-konform: AES-256 nach Art. 32\n🤖 KI-Zugriff: NICHT MÖGLICH\n📋 Audit-Log: /var/log/audit/audit.log\n\nTreesor öffnen: Rechtsklick Desktop → Tresor öffnen" 2>/dev/null
