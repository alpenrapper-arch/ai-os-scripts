#!/bin/bash
# Tresor-Status und Audit-Log anzeigen

CONF="$HOME/.config/ai-os/tresor.conf"
[ ! -f "$CONF" ] && kdialog --error "Kein Tresor vorhanden." 2>/dev/null && exit 1
source "$CONF"

MOUNT_STATUS=$(mountpoint -q "$TRESOR_MOUNT" 2>/dev/null && echo "🔓 GEÖFFNET" || echo "🔒 GESPERRT")
CREATED_DATE=$(grep CREATED "$CONF" | cut -d= -f2)
TRESOR_SIZE=$(du -sh "$TRESOR_FILE" 2>/dev/null | cut -f1)

# Letzte 10 Zugriffe aus syslog
AUDIT=$(grep "privat-tresor" /var/log/syslog 2>/dev/null | tail -10 | \
  sed 's/.*privat-tresor\[.*\]: //' || echo "(Kein Audit-Log verfügbar)")

kdialog --title "Privat-Tresor Status" \
  --msgbox "🔒 PRIVAT-TRESOR STATUS\n\nStatus: $MOUNT_STATUS\nErstellt: $CREATED_DATE\nGröße: $TRESOR_SIZE\nVerschlüsselung: AES-256-XTS (LUKS2)\nKey-Ableitung: Argon2id\n\n📋 AUDIT-LOG (letzte Einträge):\n$AUDIT\n\n🛡️ DSGVO Art. 32 — Technische Maßnahmen: ✅\n🤖 KI-Zugriff blockiert: ✅ (Kernel-Ebene)\n🔍 Audit-sicher: ✅ (syslog + auditd)" 2>/dev/null
